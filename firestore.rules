rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isClient() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'client';
    }
    
    function isRep() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rep';
    }
    
    // USERS collection - users can read/write their own data only
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
    
    // CLIENTS collection - read-only for clients, full access for admin
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // REPS collection - read-only for reps and clients, full access for admin
    match /reps/{repId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ENGAGEMENTS collection - role-based access
    match /engagements/{engagementId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isClient() && resource.data.clientId == request.auth.uid) ||
        (isRep() && resource.data.repId == request.auth.uid)
      );
      
      allow create: if isAuthenticated() && isClient();
      
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isClient() && resource.data.clientId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'paymentStatus'])) ||
        (isRep() && resource.data.repId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['debrief', 'status']))
      );
      
      allow delete: if isAdmin();
    }
    
    // INVOICES collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (isClient() && resource.data.clientId == request.auth.uid)
      );
      allow write: if isAdmin();
      allow create: if isAdmin();
    }
    
    // PAYMENTS collection - sensitive data, admin only
    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // NOTIFICATIONS collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}