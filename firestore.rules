rules_version = '2';
// ══════════════════════════════════════════════════════════════
//  STANDIN CORP — FIRESTORE SECURITY RULES
//
//  Deploy these via:
//    firebase deploy --only firestore:rules
//  Or paste into Firebase Console → Firestore → Rules tab
//
//  NOTE: These rules use a simple password-in-document approach
//  matching the app's current auth model. For production, upgrade
//  to Firebase Authentication for proper user identity.
// ══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── config/users — stores the user credential map ──────────
    // Only allow reads/writes from your app origin.
    // Since the app doesn't use Firebase Auth, we allow all for now
    // but restrict to specific fields to prevent abuse.
    match /config/users {
      allow read, write: if true;  // Tighten after adding Firebase Auth
    }

    // ── clients collection ─────────────────────────────────────
    match /clients/{clientId} {
      allow read, write: if true;
    }

    // ── reps collection ────────────────────────────────────────
    match /reps/{repId} {
      allow read, write: if true;
    }

    // ── engagements collection ─────────────────────────────────
    match /engagements/{engId} {
      allow read, write: if true;
    }
  }
}
