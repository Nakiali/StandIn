rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function usersDocData() {
      return get(/databases/$(database)/documents/standin_data/users).data;
    }

    function emailInUsersMap() {
      return exists(/databases/$(database)/documents/standin_data/users)
          && request.auth.token.email in usersDocData().map;
    }

    function userRole() {
      return usersDocData().map[request.auth.token.email].role;
    }

    function isAdmin()  { return isSignedIn() && emailInUsersMap() && userRole() == 'admin'; }
    function isClient() { return isSignedIn() && emailInUsersMap() && userRole() == 'client'; }
    function isRep()    { return isSignedIn() && emailInUsersMap() && userRole() == 'rep'; }

    // ── standin_data — the active collection ─────────────────────────
    match /standin_data/{doc} {

      // ── users document ────────────────────────────────────────────
      // Any signed-in user may read (needed to resolve their own role on login).
      // Write rules:
      //   - Admin: full access to manage all user records.
      //   - New registrant (not yet in map): may write ONLY their own email entry,
      //     and may NOT promote themselves to 'admin'.
      //   - Existing rep/client: may update ONLY their own profile fields.
      //     They cannot change their own role or any other user's record.
      allow read: if isSignedIn();

      allow write: if
        // Admins have full write access
        isAdmin()

        // New self-registration: email not yet in the map, and incoming role != admin
        || (
          doc == 'users'
          && isSignedIn()
          && !emailInUsersMap()
          && request.resource.data.map[request.auth.token.email].role != 'admin'
        )

        // Existing user updating only their own profile — role cannot change
        || (
          doc == 'users'
          && isSignedIn()
          && emailInUsersMap()
          && (isClient() || isRep())
          && request.resource.data.map[request.auth.token.email].role
             == resource.data.map[request.auth.token.email].role
        );

      // ── clients document ──────────────────────────────────────────
      // Reps cannot access client financial/contact data.
      // Admins: full access. Clients: read + write their own registration.
      // New registrants (no role yet): write allowed during sign-up.
      allow read:  if isAdmin() || isClient();
      allow write: if isAdmin()
                   || isClient()
                   || (isSignedIn() && !emailInUsersMap());

      // ── reps document ─────────────────────────────────────────────
      // All signed-in users may read (clients browse reps during booking).
      // Admins: full access. Reps/clients: allowed writes for profile updates,
      // ratings, and self-registration. New registrants: allowed during sign-up.
      allow read:  if isSignedIn();
      allow write: if isAdmin()
                   || isRep()
                   || isClient()
                   || (isSignedIn() && !emailInUsersMap());

      // ── engagements document ──────────────────────────────────────
      // All authenticated roles read and write.
      // Clients book, reps submit debriefs, admins manage status.
      allow read, write: if isSignedIn();
    }

    // ── Legacy collection paths — locked down ────────────────────────
    match /standin_users/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /standin_clients/{doc} {
      allow read:  if isAdmin() || isClient();
      allow write: if isAdmin();
    }
    match /standin_reps/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() || isRep();
    }
    match /standin_engagements/{doc} {
      allow read, write: if isSignedIn();
    }
  }
}
