rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // standin_data collection — all 4 documents (users, clients, reps, engagements)
    // Require a valid Firebase Auth session for every read and write.
    // This replaces the previous "allow read, write: if true" which was open to anyone.
    match /standin_data/{doc} {
      allow read, write: if request.auth != null;
    }

    // Legacy paths — also require auth
    match /standin_users/{doc} {
      allow read, write: if request.auth != null;
    }
    match /standin_clients/{doc} {
      allow read, write: if request.auth != null;
    }
    match /standin_reps/{doc} {
      allow read, write: if request.auth != null;
    }
    match /standin_engagements/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
